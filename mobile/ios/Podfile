# Standard Flutter Podfile
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously, which can slow down pod install.
ENV['COCOAPODS_ABLE_STATS'] = '1'

# Load the Flutter podhelper script
load File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb')

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Install all pods for the Flutter app
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Call the Flutter post-install hook
    flutter_additional_ios_build_settings(target)
    
    # Force alignment of deployment target to 13.0 for all dependencies
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      # Xcode 15+ sandboxing fix
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
    end
  end
end
