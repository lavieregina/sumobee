# Standard Flutter Podfile
platform :ios, '13.0'

# Load the Flutter podhelper script
flutter_root = ENV['FLUTTER_ROOT'] || File.join('..', '..', 'flutter') # Fallback to local if exist
podhelper_path = File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
# If not found in SDK path, fallback to local file
podhelper_path = File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb') unless File.exist?(podhelper_path)

load podhelper_path

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Install all pods for the Flutter app
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Call the Flutter post-install hook
    flutter_additional_ios_build_settings(target)
    
    # Configure build settings for all targets
    target.build_configurations.each do |config|
      # Xcode 15+ sandboxing fix
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      # Force bitcode off for consistency
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end
